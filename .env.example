# Core service credentials
LITELLM_MASTER_KEY=sk-local-change-me
LITELLM_SALT_KEY=local-salt-change-me

# PostgreSQL
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-now
POSTGRES_DB=litellm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://litellm:change-me-now@postgres:5432/litellm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Host-native Ollama (WSL host)
OLLAMA_API_BASE=http://host.docker.internal:11434

# LiteLLM startup
ENABLE_DB_MIGRATIONS=true
DISABLE_BACKGROUND_BUDGET_RESET=true
