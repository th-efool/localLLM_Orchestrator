# LiteLLM security
LITELLM_MASTER_KEY=sk-local-change-me
LITELLM_SALT_KEY=local-salt-change-me

# SQLite default for single-node use
DATABASE_URL=sqlite:////app/proxy_server_db/litellm.db

# Use host Ollama by default (Windows/WSL2 Docker Desktop)
OLLAMA_API_BASE=http://host.docker.internal:11434

# Optional local Ollama container tuning (used only with profile: with-ollama)
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=2

# Optional vLLM model pulls
HUGGING_FACE_HUB_TOKEN=
VLLM_DUMMY_API_KEY=not-used
