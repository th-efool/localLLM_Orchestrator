# Local AI stack workstation defaults. Copy to .env.

# Compose
COMPOSE_PROJECT_NAME=local-ai-stack
COMPOSE_PROFILES=

# LiteLLM credentials
LITELLM_MASTER_KEY=sk-local-change-me
LITELLM_SALT_KEY=local-salt-change-me

# PostgreSQL
POSTGRES_USER=localai
POSTGRES_PASSWORD=localai_password
POSTGRES_DB=litellm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://localai:localai_password@postgres:5432/litellm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Host-native Ollama; do not run duplicate containerized Ollama.
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_FALLBACK_HOSTS=
OLLAMA_CONNECT_RETRIES=6
OLLAMA_CONNECT_SLEEP=2
OLLAMA_CONNECT_TIMEOUT=5

# LiteLLM runtime
ENABLE_DB_MIGRATIONS=true
DISABLE_BACKGROUND_BUDGET_RESET=true
STORE_MODEL_IN_DB=True
DISABLE_PRISMA_GENERATE=true
LITELLM_DISABLE_AUTO_MIGRATIONS=true
LITELLM_LOG=INFO
PYTHONUNBUFFERED=1
MODEL_DISCOVERY_RETRIES=20
MODEL_DISCOVERY_SLEEP=2

# Optional vLLM runtime (start with: make up-vllm)
VLLM_API_BASE=
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
HUGGING_FACE_HUB_TOKEN=

# Local client defaults
OPENAI_API_BASE=http://localhost:4000/v1
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_API_KEY=sk-local-change-me
FAST_MODEL=phi4
REASON_MODEL=qwen3.5:35b
AGENT_MODEL=phi4
OPENHANDS_MODEL=qwen3.5:35b
OPENHANDS_FALLBACK_MODEL=phi4
DOMAIN_NAME=localhost
VERIFY_VLLM=false

# Traefik local defaults
TAILSCALE_DOMAIN=localhost
TRAEFIK_READ_TIMEOUT=30s
TRAEFIK_WRITE_TIMEOUT=120s
TRAEFIK_IDLE_TIMEOUT=120s
TRAEFIK_MAX_REQUEST_BODY_BYTES=20971520
TRAEFIK_RL_AVG=60
TRAEFIK_RL_BURST=120
TRAEFIK_RL_WEBUI_AVG=80
TRAEFIK_RL_WEBUI_BURST=160
TRAEFIK_LITELLM_INFLIGHT=80
TRAEFIK_WEBUI_INFLIGHT=120
ACME_EMAIL=admin@localhost
ENABLE_OBSERVABILITY=0
